<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Population Aging Simulation</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500;600&family=IBM+Plex+Sans:wght@300;400;500&display=swap');

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #0a0e14;
    --panel: #111620;
    --border: #1e2a38;
    --accent: #00d4ff;
    --accent2: #ff6b35;
    --accent3: #a8ff78;
    --text: #c8d8e8;
    --text-dim: #4a6070;
    --young: #00d4ff;
    --middle: #78c8ff;
    --senior: #ff9a3c;
    --elder: #ff4a6b;
  }

  body {
    font-family: 'IBM Plex Mono', monospace;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  header {
    padding: 18px 32px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--panel);
  }

  .title-block h1 {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .title-block p {
    font-size: 10px;
    color: var(--text-dim);
    letter-spacing: 0.1em;
    margin-top: 2px;
  }

  .status-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--accent3);
    box-shadow: 0 0 8px var(--accent3);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 8px var(--accent3); }
    50% { opacity: 0.5; box-shadow: 0 0 16px var(--accent3); }
  }

  .main {
    flex: 1;
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 0;
    overflow: hidden;
  }

  .sidebar {
    background: var(--panel);
    border-right: 1px solid var(--border);
    padding: 24px 20px;
    display: flex;
    flex-direction: column;
    gap: 28px;
    overflow-y: auto;
  }

  .section-label {
    font-size: 9px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 14px;
    border-bottom: 1px solid var(--border);
    padding-bottom: 6px;
  }

  .control-group { display: flex; flex-direction: column; gap: 14px; }

  .control-item label {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 11px;
    color: var(--text);
    margin-bottom: 8px;
  }

  .control-item label span {
    font-weight: 600;
    color: var(--accent);
    font-size: 12px;
  }

  .control-item input[type=range] {
    width: 100%;
    -webkit-appearance: none;
    height: 3px;
    border-radius: 2px;
    background: var(--border);
    outline: none;
    cursor: pointer;
  }

  .control-item input[type=range]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 14px; height: 14px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 8px var(--accent);
    cursor: pointer;
    transition: box-shadow 0.2s;
  }

  .control-item input[type=range]:hover::-webkit-slider-thumb {
    box-shadow: 0 0 16px var(--accent);
  }

  .control-item.retirement input[type=range]::-webkit-slider-thumb {
    background: var(--accent2);
    box-shadow: 0 0 8px var(--accent2);
  }

  .control-item.lifeexp input[type=range]::-webkit-slider-thumb {
    background: var(--accent3);
    box-shadow: 0 0 8px var(--accent3);
  }

  .metrics { display: flex; flex-direction: column; gap: 12px; }

  .metric-card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 12px 14px;
    position: relative;
    overflow: hidden;
  }

  .metric-card::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
  }

  .metric-card.population::before { background: var(--accent); }
  .metric-card.growth::before { background: var(--accent3); }
  .metric-card.aging::before { background: var(--accent2); }

  .metric-label {
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 6px;
  }

  .metric-value {
    font-size: 22px;
    font-weight: 600;
    color: var(--text);
    line-height: 1;
  }

  .metric-card.population .metric-value { color: var(--accent); }
  .metric-card.growth .metric-value { color: var(--accent3); }
  .metric-card.aging .metric-value { color: var(--accent2); }

  .metric-sub {
    font-size: 9px;
    color: var(--text-dim);
    margin-top: 4px;
  }

  /* Canvas area */
  .canvas-area {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 32px 40px;
    gap: 0;
    overflow: hidden;
  }

  .timeline-label {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 10px;
  }

  .timeline-label span {
    font-size: 9px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  .canvas-wrapper {
    flex: 1;
    position: relative;
    min-height: 0;
  }

  canvas {
    display: block;
    width: 100%;
    height: 100%;
  }

  .age-axis {
    display: flex;
    justify-content: space-between;
    margin-top: 8px;
    position: relative;
  }

  .age-axis span {
    font-size: 9px;
    color: var(--text-dim);
    letter-spacing: 0.05em;
  }

  .legend {
    display: flex;
    gap: 20px;
    margin-top: 16px;
    padding-top: 14px;
    border-top: 1px solid var(--border);
    flex-wrap: wrap;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 10px;
    color: var(--text-dim);
  }

  .legend-dot {
    width: 9px; height: 9px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .retirement-line-label {
    position: absolute;
    font-size: 9px;
    color: var(--accent2);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    pointer-events: none;
    white-space: nowrap;
  }

  .grid-line {
    position: absolute;
    top: 0; bottom: 0;
    width: 1px;
    border-left: 1px dashed;
    pointer-events: none;
  }

  .tooltip {
    position: absolute;
    background: var(--panel);
    border: 1px solid var(--border);
    padding: 6px 10px;
    font-size: 10px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s;
    border-radius: 2px;
    z-index: 10;
  }
</style>
</head>
<body>
<header>
  <div class="title-block">
    <h1>Population Aging Simulation</h1>
    <p>Demographic lifecycle model · real-time</p>
  </div>
  <div class="status-dot"></div>
</header>

<div class="main">
  <div class="sidebar">
    <div>
      <div class="section-label">Parameters</div>
      <div class="control-group">
        <div class="control-item">
          <label>Birth Rate <span id="birthRateVal">30</span>/yr</label>
          <input type="range" id="birthRate" min="5" max="80" value="30" step="1">
        </div>
        <div class="control-item lifeexp">
          <label>Life Expectancy <span id="lifeExpVal">80</span> yrs</label>
          <input type="range" id="lifeExp" min="40" max="100" value="80" step="1">
        </div>
        <div class="control-item retirement">
          <label>Retirement Age <span id="retirementVal">65</span> yrs</label>
          <input type="range" id="retirementAge" min="40" max="85" value="65" step="1">
        </div>
      </div>
    </div>

    <div>
      <div class="section-label">Metrics</div>
      <div class="metrics">
        <div class="metric-card population">
          <div class="metric-label">Total Population</div>
          <div class="metric-value" id="totalPop">0</div>
          <div class="metric-sub">individuals on timeline</div>
        </div>
        <div class="metric-card growth">
          <div class="metric-label">Natural Growth Rate</div>
          <div class="metric-value" id="growthRate">+0.0</div>
          <div class="metric-sub">Δ per second</div>
        </div>
        <div class="metric-card aging">
          <div class="metric-label">Aging Population</div>
          <div class="metric-value" id="agingProp">0.0%</div>
          <div class="metric-sub">above retirement age</div>
        </div>
      </div>
    </div>

    <div>
      <div class="section-label">Color Legend</div>
      <div class="legend" style="flex-direction:column;gap:8px;margin:0;padding:0;border:none;">
        <div class="legend-item"><div class="legend-dot" style="background:var(--young)"></div>Young (0–30)</div>
        <div class="legend-item"><div class="legend-dot" style="background:var(--middle)"></div>Middle-aged (30–retirement)</div>
        <div class="legend-item"><div class="legend-dot" style="background:var(--senior)"></div>Senior (retirement–80)</div>
        <div class="legend-item"><div class="legend-dot" style="background:var(--elder)"></div>Elder (80+)</div>
      </div>
    </div>
  </div>

  <div class="canvas-area">
    <div class="timeline-label">
      <span>← Birth</span>
      <span>Timeline · Age Progression</span>
      <span>Life End →</span>
    </div>
    <div class="canvas-wrapper">
      <canvas id="simCanvas"></canvas>
    </div>
    <div class="age-axis" id="ageAxis"></div>
    <div class="legend">
      <div class="legend-item"><div class="legend-dot" style="background:var(--young)"></div>Young</div>
      <div class="legend-item"><div class="legend-dot" style="background:var(--middle)"></div>Working Age</div>
      <div class="legend-item"><div class="legend-dot" style="background:var(--accent2)"></div>Retired</div>
      <div class="legend-item"><div class="legend-dot" style="background:var(--elder)"></div>Elder (80+)</div>
      <div class="legend-item" style="margin-left:auto;">
        <div style="width:18px;height:1px;border-top:1px dashed var(--accent2);margin-top:1px;"></div>
        Retirement threshold
      </div>
    </div>
  </div>
</div>

<script>
const canvas = document.getElementById('simCanvas');
const ctx = canvas.getContext('2d');

let params = {
  birthRate: 30,
  lifeExp: 80,
  retirementAge: 65
};

let spheres = [];
let lastSpawnTime = 0;
let spawnInterval = 1000 / params.birthRate;
let lastTime = null;
let popHistory = [];
const HISTORY_LEN = 120;

class Sphere {
  constructor() {
    this.age = 0;
    this.vy = (Math.random() - 0.5) * 0.3;
    this.vySeed = Math.random() * Math.PI * 2;
    this.vyFreq = 0.5 + Math.random() * 0.5;
    this.radius = 4 + Math.random() * 3;
    this.opacity = 0;
    this.fadeIn = true;
    this.id = Math.random();
    this.laneOffset = (Math.random() - 0.5) * 0.7;
  }

  get progress() { return this.age / params.lifeExp; }

  getColor() {
    const r = params.retirementAge / params.lifeExp;
    const p = this.progress;
    const youngEnd = 30 / params.lifeExp;
    if (p < youngEnd) return `rgba(0, 212, 255, ${this.opacity})`;
    if (p < r) return `rgba(120, 200, 255, ${this.opacity})`;
    if (this.age < 80) return `rgba(255, 154, 60, ${this.opacity})`;
    return `rgba(255, 74, 107, ${this.opacity})`;
  }

  getGlow() {
    const r = params.retirementAge / params.lifeExp;
    const p = this.progress;
    const youngEnd = 30 / params.lifeExp;
    if (p < youngEnd) return 'rgba(0, 212, 255, 0.4)';
    if (p < r) return 'rgba(120, 200, 255, 0.3)';
    if (this.age < 80) return 'rgba(255, 154, 60, 0.5)';
    return 'rgba(255, 74, 107, 0.6)';
  }
}

function resizeCanvas() {
  const wrapper = canvas.parentElement;
  canvas.width = wrapper.clientWidth;
  canvas.height = wrapper.clientHeight;
  buildAgeAxis();
}

function buildAgeAxis() {
  const axis = document.getElementById('ageAxis');
  axis.innerHTML = '';
  const steps = [0, 20, 40, 60, params.retirementAge, params.lifeExp];
  const unique = [...new Set(steps)].sort((a, b) => a - b);
  unique.forEach(age => {
    const span = document.createElement('span');
    span.textContent = age;
    span.style.position = 'absolute';
    const pct = age / params.lifeExp * 100;
    span.style.left = pct + '%';
    span.style.transform = 'translateX(-50%)';
    if (age === params.retirementAge) span.style.color = 'var(--accent2)';
    axis.appendChild(span);
  });
}

function spawnSphere() {
  spheres.push(new Sphere());
}

let prevTotal = 0;
function updateMetrics(dt) {
  const total = spheres.length;
  const retired = spheres.filter(s => s.age >= params.retirementAge).length;
  const aging = total > 0 ? (retired / total * 100) : 0;

  popHistory.push(total);
  if (popHistory.length > HISTORY_LEN) popHistory.shift();

  let growth = 0;
  if (popHistory.length >= 10) {
    const recent = popHistory.slice(-10);
    const older = popHistory.slice(-20, -10);
    if (older.length > 0) {
      const avgRecent = recent.reduce((a, b) => a + b, 0) / recent.length;
      const avgOlder = older.reduce((a, b) => a + b, 0) / older.length;
      growth = (avgRecent - avgOlder) / dt / 10;
    }
  }

  document.getElementById('totalPop').textContent = total;
  document.getElementById('agingProp').textContent = aging.toFixed(1) + '%';
  const gEl = document.getElementById('growthRate');
  const gVal = (total - prevTotal);
  gEl.textContent = (gVal >= 0 ? '+' : '') + gVal.toFixed(0);
  gEl.style.color = gVal >= 0 ? 'var(--accent3)' : 'var(--elder)';
  prevTotal = total;
}

function drawBackground() {
  ctx.fillStyle = '#0a0e14';
  ctx.fillRect(0, 0, canvas.width, canvas.height);

  // Subtle horizontal bands
  const bandH = canvas.height / 8;
  for (let i = 0; i < 8; i++) {
    const alpha = (i % 2 === 0) ? 0.012 : 0;
    ctx.fillStyle = `rgba(30,50,80,${alpha})`;
    ctx.fillRect(0, i * bandH, canvas.width, bandH);
  }

  // Vertical grid lines at decade marks
  ctx.setLineDash([3, 6]);
  ctx.lineWidth = 1;
  for (let age = 10; age < params.lifeExp; age += 10) {
    const x = (age / params.lifeExp) * canvas.width;
    ctx.strokeStyle = age === params.retirementAge ? 'rgba(255,107,53,0.18)' : 'rgba(30,50,80,0.4)';
    ctx.beginPath();
    ctx.moveTo(x, 0);
    ctx.lineTo(x, canvas.height);
    ctx.stroke();
  }
  ctx.setLineDash([]);

  // Birth zone glow
  const birthGrad = ctx.createLinearGradient(0, 0, canvas.width * 0.12, 0);
  birthGrad.addColorStop(0, 'rgba(0,212,255,0.07)');
  birthGrad.addColorStop(1, 'rgba(0,212,255,0)');
  ctx.fillStyle = birthGrad;
  ctx.fillRect(0, 0, canvas.width * 0.12, canvas.height);

  // Death zone glow
  const deathGrad = ctx.createLinearGradient(canvas.width * 0.88, 0, canvas.width, 0);
  deathGrad.addColorStop(0, 'rgba(255,74,107,0)');
  deathGrad.addColorStop(1, 'rgba(255,74,107,0.07)');
  ctx.fillStyle = deathGrad;
  ctx.fillRect(canvas.width * 0.88, 0, canvas.width * 0.12, canvas.height);

  // Retirement line
  const rx = (params.retirementAge / params.lifeExp) * canvas.width;
  ctx.save();
  ctx.strokeStyle = 'rgba(255,107,53,0.55)';
  ctx.lineWidth = 1.5;
  ctx.setLineDash([6, 4]);
  ctx.beginPath();
  ctx.moveTo(rx, 0);
  ctx.lineTo(rx, canvas.height);
  ctx.stroke();
  ctx.setLineDash([]);

  ctx.fillStyle = 'rgba(255,107,53,0.85)';
  ctx.font = '9px IBM Plex Mono';
  ctx.letterSpacing = '0.1em';
  ctx.textAlign = 'center';
  ctx.fillText('RETIREMENT', rx, 12);
  ctx.fillText(`AGE ${params.retirementAge}`, rx, 23);
  ctx.restore();
}

function drawSphere(s) {
  const x = (s.age / params.lifeExp) * canvas.width;
  const baseY = canvas.height / 2 + s.laneOffset * canvas.height * 0.38;
  const wobble = Math.sin(s.vySeed + Date.now() * 0.001 * s.vyFreq) * canvas.height * 0.04;
  const y = baseY + wobble;

  // Glow
  const grd = ctx.createRadialGradient(x, y, 0, x, y, s.radius * 4);
  grd.addColorStop(0, s.getGlow());
  grd.addColorStop(1, 'rgba(0,0,0,0)');
  ctx.fillStyle = grd;
  ctx.beginPath();
  ctx.arc(x, y, s.radius * 4, 0, Math.PI * 2);
  ctx.fill();

  // Core sphere with shine
  const sGrd = ctx.createRadialGradient(x - s.radius * 0.3, y - s.radius * 0.3, s.radius * 0.1, x, y, s.radius);
  const col = s.getColor();
  sGrd.addColorStop(0, col.replace(/[\d.]+\)$/, `${Math.min(1, s.opacity + 0.2)})`));
  sGrd.addColorStop(0.5, col);
  sGrd.addColorStop(1, col.replace(/[\d.]+\)$/, `${s.opacity * 0.4})`));
  ctx.beginPath();
  ctx.arc(x, y, s.radius, 0, Math.PI * 2);
  ctx.fillStyle = sGrd;
  ctx.fill();

  // Specular
  ctx.beginPath();
  ctx.arc(x - s.radius * 0.3, y - s.radius * 0.3, s.radius * 0.28, 0, Math.PI * 2);
  ctx.fillStyle = `rgba(255,255,255,${s.opacity * 0.6})`;
  ctx.fill();
}

function drawDensityBar() {
  // Mini density histogram at the bottom
  const barH = 30;
  const barY = canvas.height - barH - 2;
  const bins = 60;
  const counts = new Array(bins).fill(0);

  for (const s of spheres) {
    const bin = Math.min(bins - 1, Math.floor(s.progress * bins));
    counts[bin]++;
  }

  const maxCount = Math.max(1, ...counts);
  for (let i = 0; i < bins; i++) {
    const x = (i / bins) * canvas.width;
    const w = canvas.width / bins - 1;
    const h = (counts[i] / maxCount) * barH;
    const agePos = (i / bins);
    const retirePos = params.retirementAge / params.lifeExp;
    const alpha = 0.35;
    let color;
    if (agePos < 30 / params.lifeExp) color = `rgba(0,212,255,${alpha})`;
    else if (agePos < retirePos) color = `rgba(120,200,255,${alpha})`;
    else if (agePos * params.lifeExp < 80) color = `rgba(255,154,60,${alpha})`;
    else color = `rgba(255,74,107,${alpha})`;

    ctx.fillStyle = color;
    ctx.fillRect(x, barY + (barH - h), w, h);
  }

  ctx.strokeStyle = 'rgba(30,50,80,0.5)';
  ctx.lineWidth = 1;
  ctx.strokeRect(0, barY, canvas.width, barH);

  ctx.fillStyle = 'rgba(74,96,112,0.8)';
  ctx.font = '8px IBM Plex Mono';
  ctx.textAlign = 'left';
  ctx.fillText('AGE DISTRIBUTION', 6, barY + 10);
}

function loop(ts) {
  if (!lastTime) lastTime = ts;
  const dt = Math.min((ts - lastTime) / 1000, 0.1);
  lastTime = ts;

  // Spawn
  lastSpawnTime += dt * 1000;
  spawnInterval = 1000 / params.birthRate;
  while (lastSpawnTime >= spawnInterval) {
    spawnSphere();
    lastSpawnTime -= spawnInterval;
  }

  // Update ages
  const ageSpeed = params.lifeExp / 30; // traverse in ~30 real seconds
  for (const s of spheres) {
    s.age += ageSpeed * dt;
    if (s.fadeIn) {
      s.opacity = Math.min(1, s.opacity + dt * 4);
      if (s.opacity >= 1) s.fadeIn = false;
    }
    // Fade near death
    const lifeLeft = params.lifeExp - s.age;
    if (lifeLeft < 2) s.opacity = Math.max(0, lifeLeft / 2);
  }

  // Remove dead
  spheres = spheres.filter(s => s.age < params.lifeExp);

  // Draw
  resizeCanvasIfNeeded();
  drawBackground();
  for (const s of spheres) drawSphere(s);
  drawDensityBar();

  updateMetrics(dt);
  requestAnimationFrame(loop);
}

let lastW = 0, lastH = 0;
function resizeCanvasIfNeeded() {
  const wrapper = canvas.parentElement;
  const w = wrapper.clientWidth, h = wrapper.clientHeight;
  if (w !== lastW || h !== lastH) {
    canvas.width = w;
    canvas.height = h;
    lastW = w; lastH = h;
    buildAgeAxis();
  }
}

// Controls
document.getElementById('birthRate').addEventListener('input', e => {
  params.birthRate = +e.target.value;
  document.getElementById('birthRateVal').textContent = params.birthRate;
});

document.getElementById('lifeExp').addEventListener('input', e => {
  params.lifeExp = +e.target.value;
  document.getElementById('lifeExpVal').textContent = params.lifeExp;
  // Clamp retirement
  if (params.retirementAge >= params.lifeExp) {
    params.retirementAge = params.lifeExp - 1;
    document.getElementById('retirementAge').value = params.retirementAge;
    document.getElementById('retirementVal').textContent = params.retirementAge;
  }
  buildAgeAxis();
});

document.getElementById('retirementAge').addEventListener('input', e => {
  params.retirementAge = Math.min(+e.target.value, params.lifeExp - 1);
  e.target.value = params.retirementAge;
  document.getElementById('retirementVal').textContent = params.retirementAge;
  buildAgeAxis();
});

window.addEventListener('resize', buildAgeAxis);

// Init
resizeCanvas();
requestAnimationFrame(loop);
</script>
</body>
</html>
